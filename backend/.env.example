# ============================================================
# SmartPol AI – Backend Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# Django Core
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend URL (used in password reset links)
FRONTEND_URL=http://localhost:5173

# ============================================================
# Gmail SMTP Configuration
# 1. Go to your Google Account → Security → 2-Step Verification (enable)
# 2. Then: Security → App Passwords → generate one for "Mail"
# 3. Paste the 16-char App Password below (no spaces)
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=SmartPol AI <your-gmail@gmail.com>
